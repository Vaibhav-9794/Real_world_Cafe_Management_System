generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id           String        @id @default(uuid())
  name         String
  city         String
  address      String
  phone        String
  whatsapp     String
  email        String
  openingHours String        @map("opening_hours")
  reservations Reservation[]
  staff        Staff[]
  tables       Table[]
  waitlist     Waitlist[]

  @@map("branches")
}

model Table {
  id           String        @id @default(uuid())
  number       String
  capacity     Int
  status       String
  x            Float         @default(0.0)
  y            Float         @default(0.0)
  branchId     String        @map("branch_id")
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reservations Reservation[] @relation("ReservationToTable")

  @@map("tables")
}

model Reservation {
  id                   String    @id @default(uuid())
  name                 String
  email                String
  phone                String
  type                 String
  booking_type         String    @default("TABLE")
  table_number         Int?
  table_capacity       Int?
  guest_count          Int       @default(0)
  reservation_date     String
  start_time           String
  end_time             String
  booking_status       String    @default("PENDING")
  special_requests     String?
  approval_status      String    @default("PENDING")
  approved_by          String?
  approved_at          DateTime?
  rejection_reason     String?
  is_full_cafe_booking Boolean   @default(false)
  held_until           DateTime?
  sessionId            String?   @map("session_id")
  date                 String
  time                 String
  guests               Int
  notes                String?
  status               String    @default("PENDING_APPROVAL")
  paymentStatus        String    @default("PENDING") @map("payment_status")
  paymentId            String?   @map("payment_id")
  paymentAmount        Float     @default(0.0) @map("payment_amount")
  paymentGateway       String?   @map("payment_gateway")
  createdAt            DateTime  @default(now()) @map("created_at")
  branchId             String    @map("branch_id")
  couponCode           String?   @map("coupon_code")
  pointsAwarded        Int       @default(0) @map("points_awarded")
  orders               Order[]
  payments             Payment[]
  coupon               Coupon?   @relation(fields: [couponCode], references: [code])
  branch               Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tables               Table[]   @relation("ReservationToTable")

  @@index([branchId, reservation_date, booking_status])
  @@index([reservation_date])
  @@map("reservations")
}

model Waitlist {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  guests    Int
  date      String
  timeSlot  String   @map("time_slot")
  status    String   @default("WAITING")
  createdAt DateTime @default(now()) @map("created_at")
  branchId  String   @map("branch_id")
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("waitlist")
}

model Customer {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  phone               String    @unique
  visitCount          Int       @default(0) @map("visit_count")
  totalSpent          Float     @default(0.0) @map("total_spent")
  points              Int       @default(0)
  vipStatus           Boolean   @default(false) @map("vip_status")
  membershipTier      String    @default("Bronze") @map("membership_tier")
  birthday            String?
  notes               String?
  preferredTable      Int?      @map("preferred_table")
  dietaryRestrictions String?   @map("dietary_restrictions")
  averageGroupSize    Float     @default(2.0) @map("average_group_size")
  lastVisitDate       String?   @map("last_visit_date")
  referredBy          String?   @map("referred_by")
  referralCode        String?   @unique @map("referral_code")
  createdAt           DateTime  @default(now()) @map("created_at")
  otpCode             String?   @map("otp_code")
  otpExpires          DateTime? @map("otp_expires")
  password            String?
  resetToken          String?   @map("reset_token")
  resetTokenExpires   DateTime? @map("reset_token_expires")

  @@map("customers")
}

model CustomerFavorite {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  itemId     String   @map("item_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([customerId, itemId])
  @@map("customer_favorites")
}

model Coupon {
  code         String        @id
  type         String
  value        Float
  minSpend     Float         @default(0.0) @map("min_spend")
  startDate    String        @map("start_date")
  endDate      String        @map("end_date")
  usageLimit   Int           @default(100) @map("usage_limit")
  usageCount   Int           @default(0) @map("usage_count")
  reservations Reservation[]

  @@map("coupons")
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  type      String
  source    String
  notes     String?
  status    String   @default("NEW")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("leads")
}

model Staff {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  role        String
  pin         String
  loginMethod String   @default("PIN") @map("login_method")
  status      String   @default("ACTIVE")
  branchId    String?  @map("branch_id")
  createdAt   DateTime @default(now()) @map("created_at")
  branch      Branch?  @relation(fields: [branchId], references: [id])

  @@map("staff")
}

model CMSConfig {
  key   String @id
  value String

  @@map("cms_config")
}

model BlockedDate {
  id        String   @id @default(uuid())
  date      String
  startTime String?  @map("start_time")
  endTime   String?  @map("end_time")
  reason    String?
  type      String   @default("HOLIDAY")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date, startTime, endTime])
  @@map("blocked_dates")
}

model Order {
  id            String       @id @default(uuid())
  tableNumber   Int?         @map("table_number")
  status        String       @default("PENDING")
  totalAmount   Float        @default(0.0) @map("total_amount")
  reservationId String?      @map("reservation_id")
  branchId      String       @default("downtown") @map("branch_id")
  customerEmail String?      @map("customer_email")
  customerPhone String?      @map("customer_phone")
  createdAt     DateTime     @default(now()) @map("created_at")
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@index([reservationId])
  @@index([branchId])
  @@map("orders")
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String @map("order_id")
  itemId   String @map("item_id")
  itemName String @map("item_name")
  quantity Int
  price    Float
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Payment {
  id            String       @id @default(uuid())
  orderId       String?      @map("order_id")
  reservationId String?      @map("reservation_id")
  amount        Float
  status        String       @default("PENDING")
  gateway       String
  transactionId String?      @map("transaction_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  order         Order?       @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([reservationId])
  @@map("payments")
}

model RewardRedemption {
  id           String   @id @default(uuid())
  customerId   String   @map("customer_id")
  rewardName   String   @map("reward_name")
  pointsBurned Int      @map("points_burned")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("reward_redemptions")
}

model QRScanLog {
  id          String   @id @default(uuid())
  branchId    String   @map("branch_id")
  tableNumber String   @map("table_number")
  scannedAt   DateTime @default(now()) @map("scanned_at")

  @@map("qr_scan_logs")
}

model InventoryItem {
  id           String   @id @default(uuid())
  name         String   @unique
  category     String
  quantity     Float    @default(0.0)
  unit         String
  minThreshold Float    @default(5.0) @map("min_threshold")
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@map("inventory_items")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("inbox_notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorEmail String   @map("actor_email")
  actorRole  String   @map("actor_role")
  action     String
  details    String
  targetId   String?  @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model EmailLog {
  id           String   @id @default(uuid())
  to           String
  subject      String
  body         String
  status       String
  errorMessage String?  @map("error_message")
  attempts     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("email_logs")
}
